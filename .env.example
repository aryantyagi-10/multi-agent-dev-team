# Postgres
POSTGRES_USER=agentuser
POSTGRES_PASSWORD=agentpass
POSTGRES_DB=agentdb
POSTGRES_HOST=postgres_db
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis_cache
REDIS_PORT=6379

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka_broker:9092
KAFKA_JOB_TOPIC=agent_jobs

# JWT
JWT_SECRET_KEY=super_secret_jwt_token_key_
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# LLM (OpenAI-compatible). Point base_url at your provider if not OpenAI.
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.1-8b-instant

# Backend
BACKEND_URL=[fastapi_backend](http://fastapi_backend:8000)
